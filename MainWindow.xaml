<Window x:Class="MemoryMonitorBall.MainWindow"
        x:Name="Root"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="&#x5185;&#x5B58;&#x76D1;&#x63A7;&#x7403;"
        Icon="Assets/memory-ball.ico"
        Width="104"
        Height="104"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        LocationChanged="Window_LocationChanged">
    <Window.Resources>
        <Style x:Key="PanelButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EDF2F7" />
            <Setter Property="RowHeight" Value="30" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="IsReadOnly" Value="True" />
        </Style>
    </Window.Resources>

    <Grid Width="104" Height="104" Background="Transparent">
        <Border x:Name="BallSurface"
                Width="92"
                Height="92"
                CornerRadius="46"
                Background="{Binding BallBrush}"
                BorderBrush="#FFFFFF"
                BorderThickness="3"
                Cursor="Hand"
                MouseLeftButtonDown="BallSurface_MouseLeftButtonDown"
                MouseMove="BallSurface_MouseMove"
                MouseLeftButtonUp="BallSurface_MouseLeftButtonUp">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.35" />
            </Border.Effect>
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="&#x663E;&#x793A;/&#x9690;&#x85CF;&#x8BE6;&#x60C5;" Click="ToggleDetailsMenuItem_Click" />
                    <MenuItem Header="&#x667A;&#x80FD;&#x91CA;&#x653E;&#x5185;&#x5B58;" Click="ReleaseMemoryMenuItem_Click" />
                    <Separator />
                    <MenuItem Header="&#x9690;&#x85CF;&#x5230;&#x6258;&#x76D8;" Click="HideMenuItem_Click" />
                    <MenuItem Header="&#x9000;&#x51FA;" Click="ExitMenuItem_Click" />
                </ContextMenu>
            </Border.ContextMenu>

            <Grid>
                <TextBlock Text="{Binding MemoryPercentText}"
                           Foreground="#FFFFFF"
                           FontSize="24"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <TextBlock Text="&#x5185;&#x5B58;"
                           Foreground="#EAF7EF"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,18" />
            </Grid>
        </Border>

        <Popup x:Name="DetailsPopup"
               PlacementTarget="{Binding ElementName=BallSurface}"
               DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
               Placement="Right"
               HorizontalOffset="10"
               VerticalOffset="-8"
               AllowsTransparency="True"
               StaysOpen="False"
               IsOpen="{Binding IsDetailsOpen, Mode=TwoWay}"
               Closed="DetailsPopup_Closed">
            <Border Width="650"
                    Height="540"
                    Padding="16"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.22" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Width="28"
                                Height="28"
                                Content="x"
                                FontSize="18"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                Cursor="Hand"
                                Click="CloseDetailsButton_Click" />
                        <StackPanel>
                            <TextBlock Text="&#x5185;&#x5B58;&#x76D1;&#x63A7;&#x7403;"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}" />
                            <TextBlock Text="{Binding MemorySummaryText}"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10">
                            <StackPanel>
                                <TextBlock Text="&#x5185;&#x5B58;&#x5360;&#x7528;" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding MemoryPercentText}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Margin="8,0,0,0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10">
                            <StackPanel>
                                <TextBlock Text="&#x8054;&#x7F51;&#x72B6;&#x6001;" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding NetworkStatusText}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Margin="8,0,0,0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="10">
                            <StackPanel>
                                <TextBlock Text="&#x5B9E;&#x65F6;&#x7F51;&#x901F;" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding DownloadSpeedText}" Foreground="{StaticResource PrimaryTextBrush}" />
                                <TextBlock Text="{Binding UploadSpeedText}" Foreground="{StaticResource PrimaryTextBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <DockPanel Grid.Row="2" Margin="0,14,0,8">
                        <TextBlock Text="&#x7A0B;&#x5E8F;&#x72B6;&#x6001;&#x4E0E;&#x8054;&#x7F51;&#x5360;&#x7528;"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   Foreground="{StaticResource PrimaryTextBrush}" />
                    </DockPanel>

                    <DataGrid Grid.Row="3"
                              ItemsSource="{Binding Processes}"
                              SelectedItem="{Binding SelectedProcess, Mode=TwoWay}"
                              AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="&#x7A0B;&#x5E8F;" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="70" />
                            <DataGridTextColumn Header="&#x72B6;&#x6001;" Binding="{Binding StatusText}" Width="105" />
                            <DataGridTextColumn Header="&#x5185;&#x5B58;" Binding="{Binding MemoryText}" Width="95" />
                            <DataGridTextColumn Header="&#x8054;&#x7F51;&#x7F51;&#x901F;" Binding="{Binding NetworkUsageText}" Width="180" />
                            <DataGridCheckBoxColumn Header="&#x53EF;&#x7ED3;&#x675F;" Binding="{Binding CanTerminate}" Width="70" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="4" Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Button Content="&#x5237;&#x65B0;"
                                    Command="{Binding RefreshProcessesCommand}"
                                    Style="{StaticResource PanelButtonStyle}" />
                            <Button Content="&#x91CA;&#x653E;&#x5185;&#x5B58;"
                                    Command="{Binding ReleaseMemoryCommand}"
                                    Style="{StaticResource PanelButtonStyle}" />
                            <Button Content="&#x7ED3;&#x675F;&#x9009;&#x4E2D;"
                                    Command="{Binding TerminateProcessCommand}"
                                    Style="{StaticResource PanelButtonStyle}" />
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Text="{Binding StatusMessage}"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Window>
